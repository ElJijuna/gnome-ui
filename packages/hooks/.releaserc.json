{
  "tagFormat": "@gnome-ui/hooks@${version}",
  "branches": [
    "main"
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat",     "release": false },
          { "type": "fix",      "release": false },
          { "type": "perf",     "release": false },
          { "type": "refactor", "release": false },
          { "breaking": true,   "release": false },
          { "type": "feat",     "scope": "@gnome-ui/hooks", "release": "minor" },
          { "type": "fix",      "scope": "@gnome-ui/hooks", "release": "patch" },
          { "type": "perf",     "scope": "@gnome-ui/hooks", "release": "patch" },
          { "type": "refactor", "scope": "@gnome-ui/hooks", "release": "patch" },
          { "breaking": true,   "scope": "@gnome-ui/hooks", "release": "major" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "perf",
              "section": "Performance"
            },
            {
              "type": "refactor",
              "section": "Refactoring"
            },
            {
              "type": "docs",
              "section": "Documentation",
              "hidden": false
            },
            {
              "type": "chore",
              "section": "Chores",
              "hidden": true
            }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": "\ud83c\udf89 This change is included in `@gnome-ui/hooks@${nextRelease.version}`.",
        "releasedLabels": [
          "released"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "package.json"
        ],
        "message": "chore(release): @gnome-ui/hooks@${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
