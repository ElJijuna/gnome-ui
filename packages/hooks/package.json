{
  "name": "@gnome-ui/hooks",
  "version": "1.8.0",
  "description": "React hooks that expose @gnome-ui/platform APIs as idiomatic React state",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gnome-ui/platform": "*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.0.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  }
}
