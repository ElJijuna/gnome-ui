{
  "name": "@gnome-ui/hooks",
  "version": "1.27.1",
  "description": "React hooks that expose @gnome-ui/platform APIs as idiomatic React state",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./useBreakpoint": {
      "types": "./dist/useBreakpoint.d.ts",
      "import": "./dist/useBreakpoint.js",
      "require": "./dist/useBreakpoint.cjs"
    },
    "./useClipboard": {
      "types": "./dist/useClipboard.d.ts",
      "import": "./dist/useClipboard.js",
      "require": "./dist/useClipboard.cjs"
    },
    "./useColorScheme": {
      "types": "./dist/useColorScheme.d.ts",
      "import": "./dist/useColorScheme.js",
      "require": "./dist/useColorScheme.cjs"
    },
    "./useFileChooser": {
      "types": "./dist/useFileChooser.d.ts",
      "import": "./dist/useFileChooser.js",
      "require": "./dist/useFileChooser.cjs"
    },
    "./useNativeEvent": {
      "types": "./dist/useNativeEvent.d.ts",
      "import": "./dist/useNativeEvent.js",
      "require": "./dist/useNativeEvent.cjs"
    },
    "./useNotification": {
      "types": "./dist/useNotification.d.ts",
      "import": "./dist/useNotification.js",
      "require": "./dist/useNotification.cjs"
    },
    "./usePlatform": {
      "types": "./dist/usePlatform.d.ts",
      "import": "./dist/usePlatform.js",
      "require": "./dist/usePlatform.cjs"
    },
    "./useRuntime": {
      "types": "./dist/useRuntime.d.ts",
      "import": "./dist/useRuntime.js",
      "require": "./dist/useRuntime.cjs"
    },
    "./useSettings": {
      "types": "./dist/useSettings.d.ts",
      "import": "./dist/useSettings.js",
      "require": "./dist/useSettings.cjs"
    },
    "./useWindowState": {
      "types": "./dist/useWindowState.d.ts",
      "import": "./dist/useWindowState.js",
      "require": "./dist/useWindowState.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gnome-ui/platform": "*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.3",
    "vite-magic-tree-shaking": "^1.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
