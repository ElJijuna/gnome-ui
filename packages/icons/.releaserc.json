{
  "tagFormat": "@gnome-ui/icons@${version}",
  "branches": [
    "main"
  ],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {
            "type": "feat",
            "release": "minor",
            "scope": "@gnome-ui/icons"
          },
          {
            "type": "fix",
            "release": "patch",
            "scope": "@gnome-ui/icons"
          },
          {
            "type": "perf",
            "release": "patch",
            "scope": "@gnome-ui/icons"
          },
          {
            "type": "refactor",
            "release": "patch",
            "scope": "@gnome-ui/icons"
          },
          {
            "breaking": true,
            "release": "major",
            "scope": "@gnome-ui/icons"
          }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "perf",
              "section": "Performance"
            },
            {
              "type": "refactor",
              "section": "Refactoring"
            },
            {
              "type": "docs",
              "section": "Documentation",
              "hidden": false
            },
            {
              "type": "chore",
              "section": "Chores",
              "hidden": true
            }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": "\ud83c\udf89 This change is included in `@gnome-ui/icons@${nextRelease.version}`.",
        "releasedLabels": [
          "released"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "package.json"
        ],
        "message": "chore(release): @gnome-ui/icons@${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
