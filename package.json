{
  "name": "gnome-ui",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "storybook": "turbo storybook",
    "build-storybook": "turbo build-storybook",
    "typecheck": "turbo typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"packages/*/src/**/*.css\"",
    "lint:css:fix": "stylelint \"packages/*/src/**/*.css\" --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "npm run lint && npm run lint:css && npm run format:check && npm run typecheck",
    "test": "turbo test"
  },
  "overrides": {
    "vite": "^8.0.16",
    "@joshwooding/vite-plugin-react-docgen-typescript": "^0.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^9.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "globals": "^15.0.0",
    "semantic-release": "^25.0.5",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "super-configs": "^1.13.0",
    "turbo": "^2.8.20",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0"
  },
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "license": "MIT"
}
